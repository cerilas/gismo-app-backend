# Environment Variables
# Copy this file to .env and fill in the values

# PostgreSQL Connection (Railway provides this automatically)
DATABASE_URL=postgresql://postgres:PASSWORD@shuttle.proxy.rlwy.net:13584/railway

# API Security Key — set a strong random string
API_KEY=your-secret-api-key-here

# Server port (Railway sets this automatically)
PORT=3000

# Node environment
NODE_ENV=production
